<UserControl x:Class="KutuphaneOtomasyonu.WPF.Views.AddBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:KutuphaneOtomasyonu.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:AddBookViewModel />
    </UserControl.DataContext>

    <Grid Background="#F4F6F8">
        <Border Background="White" Padding="30" CornerRadius="15" BorderBrush="#D3D3D3" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="550">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Yeni Kitap Ekle" FontSize="26" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Kitap Adı -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Kitap Adı" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewBook.KitapAdi, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>

                    <!-- Yazar -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Yazar" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Authors}" DisplayMemberPath="TamAd" SelectedValuePath="YazarId"
                                  SelectedValue="{Binding NewBook.YazarId}" Padding="6"/>
                    </StackPanel>

                    <!-- Kategori -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Kategori" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="KategoriAdi" SelectedValuePath="KategoriId"
                                  SelectedValue="{Binding NewBook.KategoriId}" Padding="6"/>
                    </StackPanel>

                    <!-- Stok Adedi -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Stok Adedi" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewBook.StokAdedi, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>

                    <!-- Mevcut Adet -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Mevcut Adet (Otomatik)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewBook.MevcutAdet, UpdateSourceTrigger=PropertyChanged}" Padding="8" IsReadOnly="True" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Yayın Yılı -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Yayın Yılı" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewBook.YayinYili, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>

                    <!-- Sayfa Sayısı -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Sayfa Sayısı" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewBook.SayfaSayisi, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                    </StackPanel>

                    <!-- Açıklama -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Açıklama" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding NewBook.Aciklama, UpdateSourceTrigger=PropertyChanged}" 
                                 Padding="8" Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Buton -->
                    <Button Content="Kitap Ekle" Command="{Binding AddBookCommand}" 
                            Background="#2E8B57" Foreground="White" FontWeight="Bold"
                            Padding="10" Margin="0,0,0,10" BorderBrush="#007ACC" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Center" Width="180"/>

                    <!-- Hata / Başarı -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" FontSize="12" Margin="0,5"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="Green" HorizontalAlignment="Center" FontSize="12" Margin="0,5"/>

                    <!-- Yükleniyor -->
                    <ProgressBar IsIndeterminate="{Binding IsLoading}" Height="8" Margin="0,10,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

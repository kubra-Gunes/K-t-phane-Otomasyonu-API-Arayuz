<UserControl x:Class="KutuphaneOtomasyonu.WPF.Views.AddCategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:KutuphaneOtomasyonu.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:AddCategoryViewModel />
    </UserControl.DataContext>

    <Grid Background="#F4F6F8">
        <Border Background="White" Padding="30" CornerRadius="12" BorderBrush="#D3D3D3" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
            <StackPanel>
                <TextBlock Text="Yeni Kategori Ekle" FontSize="26" FontWeight="Bold" Foreground="#333"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Kategori Adı -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Kategori Adı" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NewCategory.KategoriAdi, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8"/>
                </StackPanel>

                <!-- Ekle Butonu -->
                <Button Content="Kategori Ekle" Command="{Binding AddCategoryCommand}"
                        Background="#2E8B57" Foreground="White" FontWeight="Bold"
                        Padding="10" Margin="0,0,0,10" BorderBrush="#007ACC" BorderThickness="1"
                        Cursor="Hand" HorizontalAlignment="Center" Width="150"/>

                <!-- Mesajlar -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                           HorizontalAlignment="Center" FontSize="12" Margin="0,5"/>
                <TextBlock Text="{Binding SuccessMessage}" Foreground="Green"
                           HorizontalAlignment="Center" FontSize="12" Margin="0,5"/>

                <!-- Yükleniyor -->
                <ProgressBar IsIndeterminate="{Binding IsLoading}" Height="8" Margin="0,10,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

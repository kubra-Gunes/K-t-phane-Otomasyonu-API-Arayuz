<Window x:Class="KutuphaneOtomasyonu.WPF.Views.AdminMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:KutuphaneOtomasyonu.WPF.ViewModels"
        xmlns:views="clr-namespace:KutuphaneOtomasyonu.WPF.Views"
        xmlns:converters="clr-namespace:KutuphaneOtomasyonu.WPF.Converters"
        mc:Ignorable="d"
        Title="Kütüphane - Yönetici Ekranı" Height="650" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Renk Paleti -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#007BFF"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#6C757D"/>
        <SolidColorBrush x:Key="AccentColor" Color="#28A745"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="CardBackgroundColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextColor" Color="#343A40"/>
        <SolidColorBrush x:Key="LightTextColor" Color="#6C757D"/>

        <!-- Yazı Tipi -->
        <FontFamily x:Key="PrimaryFont">Segoe UI</FontFamily>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Ana Buton -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056B3"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004085"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Buton -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter Margin="10,2" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E6F0FF"/>
                    <Setter Property="Foreground" Value="#007BFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D0E7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Başlıklar -->
        <Style x:Key="HeaderTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="SubHeaderTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ÜST BAR -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CardBackgroundColor}" Padding="20,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="📖 Kütüphane Yönetici Paneli" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>

            </Grid>
        </Border>

        <!-- SOL SİDEBAR -->
        <Border DockPanel.Dock="Left" Background="{StaticResource CardBackgroundColor}" Width="250" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <StackPanel Margin="15">
                <TextBlock Text="📚 Yönetim Paneli" Style="{StaticResource HeaderTextBlock}" HorizontalAlignment="Center"/>

                <!-- Liste Butonları -->
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowBooksCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📘" Margin="0,0,10,0"/>
                        <TextBlock Text="Kitap Listesi"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowCategoriesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" Margin="0,0,10,0"/>
                        <TextBlock Text="Kategori Listesi"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowAuthorsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✍️" Margin="0,0,10,0"/>
                        <TextBlock Text="Yazar Listesi"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="➕ Yeni Ekle" Style="{StaticResource SubHeaderTextBlock}" HorizontalAlignment="Center"/>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowAddBookCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕" Margin="0,0,10,0"/>
                        <TextBlock Text="Yeni Kitap"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowAddCategoryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕" Margin="0,0,10,0"/>
                        <TextBlock Text="Yeni Kategori"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowAddAuthorCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕" Margin="0,0,10,0"/>
                        <TextBlock Text="Yeni Yazar"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="🔄 Güncelle" Style="{StaticResource SubHeaderTextBlock}" HorizontalAlignment="Center"/>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowUpdateBookCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,10,0"/>
                        <TextBlock Text="Kitap Güncelle"/>
                    </StackPanel>
                </Button>

      


                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowUpdateCategoryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,10,0"/>
                        <TextBlock Text="Kategori Güncelle"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowUpdateAuthorCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,10,0"/>
                        <TextBlock Text="Yazar Güncelle"/>
                    </StackPanel>
                </Button>




                <TextBlock Text="👥 Kullanıcı İşlemleri" Style="{StaticResource SubHeaderTextBlock}" HorizontalAlignment="Center"/>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowBorrowBookCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📖" Margin="0,0,10,0"/>
                        <TextBlock Text="Ödünç İşlemi"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowReturnBookCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,10,0"/>
                        <TextBlock Text="İade Et"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowUsersCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" Margin="0,0,10,0"/>
                        <TextBlock Text="Kullanıcı Yönetimi"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ANA İÇERİK -->
        <ContentControl Content="{Binding CurrentContentViewModel}" Margin="20">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type viewmodels:PlaceholderViewModel}">
                    <TextBlock Text="{Binding Message}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="{StaticResource LightTextColor}" FontWeight="SemiBold"/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:BookListViewModel}">
                    <views:BookListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:CategoryListViewModel}">
                    <views:CategoryListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:AuthorListViewModel}">
                    <views:AuthorListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:AddBookViewModel}">
                    <views:AddBookView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:AddCategoryViewModel}">
                    <views:AddCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:AddAuthorViewModel}">
                    <views:AddAuthorView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:BorrowBookViewModel}">
                    <views:BorrowBookView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:ReturnBookViewModel}">
                    <views:ReturnBookView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:UserListViewModel}">
                    <views:UserListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:UpdateBookViewModel}">
                    <views:UpdateBookView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:UpdateCategoryViewModel}">
                    <views:UpdateCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:UpdateAuthorViewModel}">
                    <views:UpdateAuthorView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:BookDetailViewModel}">
                    <views:BookDetailView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </DockPanel>
</Window>

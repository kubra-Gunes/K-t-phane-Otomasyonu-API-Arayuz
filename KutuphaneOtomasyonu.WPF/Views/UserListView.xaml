<UserControl x:Class="KutuphaneOtomasyonu.WPF.Views.UserListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:KutuphaneOtomasyonu.WPF.Views"
             xmlns:converters="clr-namespace:KutuphaneOtomasyonu.WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1000"
             Background="{StaticResource BackgroundColor}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <!-- Satır Stili: Tek/Çift Satır Arka Planı + Hover Efekti -->
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFF0F0F0"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="0">
                    <Setter Property="Background" Value="#FFE0E0E0"/>
                </Trigger>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FFC0C0C0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF90C3FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Kullanıcı Yönetimi" Style="{StaticResource HeaderTextBlock}" Grid.Row="0" Margin="0,0,0,20"/>

        <!-- Yeni Kullanıcı Ekle -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Yeni Kullanıcı Ekle" Style="{StaticResource SubHeaderTextBlock}" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ad -->
                    <Label Content="Ad:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
                    <TextBox Text="{Binding NewUser.Ad, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="0,0,5,5"/>

                    <!-- Soyad -->
                    <Label Content="Soyad:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
                    <TextBox Text="{Binding NewUser.Soyad, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,0,5,5"/>

                    <!-- E-posta -->
                    <Label Content="E-posta:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
                    <TextBox Text="{Binding NewUser.Email, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,0,5,5"/>

                    <!-- Şifre -->
                    <Label Content="Şifre:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <PasswordBox x:Name="SifreInput" Grid.Row="3" Grid.Column="1" Margin="0,0,5,0"/>

                    <!-- Ekle Butonu -->
                    <Button Content="➕ Ekle" Grid.Row="0" Grid.Column="2" Grid.RowSpan="4"
                            Style="{StaticResource PrimaryButton}"
                            Background="#2E8B57"
                            Command="{Binding AddUserCommand}"
                            CommandParameter="{Binding ElementName=SifreInput}"/>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="5"/>
            </StackPanel>
        </Border>

        <!-- Kullanıcı Listesi -->
        <Grid Grid.Row="2">
            <DataGrid ItemsSource="{Binding Users}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="{StaticResource CardBackgroundColor}"
                      SelectedItem="{Binding SelectedUser, Mode=TwoWay}" AlternationCount="2"
                      RowStyle="{StaticResource AlternatingRowStyle}" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                    <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="*"/>
                    <DataGridTextColumn Header="Soyad" Binding="{Binding Soyad}" Width="*"/>
                    <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
            <ProgressBar Height="5" IsIndeterminate="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" VerticalAlignment="Top"/>
        </Grid>

        <!-- Alt Başlık -->
        <TextBlock Grid.Row="3" Text="Seçili Kullanıcının Ödünç Aldığı Kitaplar"
                   Style="{StaticResource SubHeaderTextBlock}" Margin="0,10,0,10"
                   Visibility="{Binding SelectedUser, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Kitap Listesi -->
        <DataGrid Grid.Row="4" ItemsSource="{Binding UserBorrowRecords}" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="{StaticResource CardBackgroundColor}"
                  Visibility="{Binding SelectedUser, Converter={StaticResource NullToVisibilityConverter}}" AlternationCount="2"
                  RowStyle="{StaticResource AlternatingRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kitap Adı" Binding="{Binding KitapAdi}" Width="2*"/>
                <DataGridTextColumn Header="Ödünç Alma" Binding="{Binding OduncAlmaTarihi, StringFormat='{}{0:dd.MM.yyyy}'}" Width="*"/>
                <DataGridTextColumn Header="Teslim Tarihi" Binding="{Binding SonTeslimTarihi, StringFormat='{}{0:dd.MM.yyyy}'}" Width="*"/>
                <DataGridCheckBoxColumn Header="Teslim Edildi" Binding="{Binding TeslimEdildi}" Width="Auto"/>
                <DataGridTextColumn Header="Gerçek Teslim" Binding="{Binding TeslimTarihi, StringFormat='{}{0:dd.MM.yyyy}'}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

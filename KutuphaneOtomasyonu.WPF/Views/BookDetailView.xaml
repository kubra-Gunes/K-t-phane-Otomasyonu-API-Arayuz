<UserControl x:Class="KutuphaneOtomasyonu.WPF.Views.BookDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KutuphaneOtomasyonu.WPF.Views"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="#FAFAFA">

    <UserControl.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#222831"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <DropShadowEffect x:Key="DropShadowEffect" Color="Black" BlurRadius="8" ShadowDepth="3" Opacity="0.3"/>
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#393E46"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="#222831"/>
        </Style>

        <!-- Puan için yıldız ikonu -->
        <DataTemplate x:Key="StarRatingTemplate">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding Stars}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#FFD700" FontSize="16" Margin="0,0,2,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding Puan, StringFormat='({0}/5)'}" Margin="5,0,0,0" Foreground="#555" VerticalAlignment="Center"/>
            </StackPanel>

        </DataTemplate>

        <!-- Boolean to Visibility converter burada yoksa eklemelisin -->

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Kitap Bilgileri -->
            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="25" Margin="0 0 0 30"
                    Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedBook.KitapAdi}" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text="Yazar:" Style="{StaticResource KeyValuePairLabelStyle}" />
                    <Button Content="{Binding SelectedBook.YazarAdSoyad}"
        Command="{Binding NavigateToAuthorCommand}"
        Style="{StaticResource LinkButton}" />
                    <TextBlock Text="Kategori:" Style="{StaticResource KeyValuePairLabelStyle}" />
                    <Button Content="{Binding SelectedBook.KategoriAdi}"
        Command="{Binding NavigateToCategoryCommand}"
        Style="{StaticResource LinkButton}" />
                    <WrapPanel Margin="0 0 0 15">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Kategori:"/>
                        <TextBlock Text="{Binding SelectedBook.KategoriAdi}" Foreground="#555"/>
                    </WrapPanel>
                    <WrapPanel Margin="0 0 0 15">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Yayın Yılı:"/>
                        <TextBlock Text="{Binding SelectedBook.YayinYili}" Foreground="#555"/>
                    </WrapPanel>
                    <WrapPanel Margin="0 0 0 15">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Sayfa Sayısı:"/>
                        <TextBlock Text="{Binding SelectedBook.SayfaSayisi}" Foreground="#555"/>
                    </WrapPanel>
                    <TextBlock Text="Açıklama" Style="{StaticResource LabelStyle}" Margin="0,20,0,8"/>
                    <TextBlock Text="{Binding SelectedBook.Aciklama}" TextWrapping="Wrap" Foreground="#444" FontSize="14" LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- Değerlendirmeler Başlığı -->
            <TextBlock Grid.Row="1" Text="Değerlendirmeler" FontSize="22" FontWeight="Bold" Foreground="#222831" Margin="0 0 0 15"/>

            <!-- Değerlendirmeler Listesi -->
            <ListView Grid.Row="2" ItemsSource="{Binding Comments}" Background="Transparent" BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden" >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="20" Margin="0 8"
                                Effect="{StaticResource DropShadowEffect}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding KullaniciAdSoyad}" FontWeight="Bold" Foreground="#222831" FontSize="15"/>

                                    <!-- Puan için yıldız göstergesi: buraya yorumdaki Puan'a göre yıldızları gösterecek bir property binding eklenmeli -->
                                    <TextBlock Grid.Column="1" Text="{Binding Puan, StringFormat='0/5 Puan'}" Foreground="#FFD700" FontWeight="Bold" FontSize="15"/>
                                </Grid>
                                <TextBlock Text="{Binding YorumTarihi, StringFormat='dd.MM.yyyy'}" FontSize="11" Foreground="#999" Margin="0,4,0,10"/>
                                <TextBlock Text="{Binding YorumMetni}" TextWrapping="Wrap" FontSize="14" Foreground="#333"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Yorum Ekleme Alanı -->
            <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="25" Margin="0,25,0,0"
                    Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock Text="Yorumunuzu Ekleyin" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#222831"/>
                    <TextBlock Text="Puanınız:" Margin="0,0,0,8" Foreground="#555"/>
                    <ComboBox SelectedItem="{Binding NewCommentRating}" Margin="0,0,0,15" FontSize="14" Width="100"
                              Background="#EFEFEF" BorderThickness="0" Padding="5">
                        <system:Int32>5</system:Int32>
                        <system:Int32>4</system:Int32>
                        <system:Int32>3</system:Int32>
                        <system:Int32>2</system:Int32>
                        <system:Int32>1</system:Int32>
                    </ComboBox>

                    <TextBox Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,20"
                             FontSize="14" Padding="10" Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="1" />

                    <Button Content="Yorumu Gönder" Command="{Binding SubmitCommentCommand}" Width="140" Height="38"
                            HorizontalAlignment="Right" Background="#393E46" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand" Padding="5,2"
                            >
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#393E46"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#222831"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#121619"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#AAA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Hata ve Yüklenme Göstergesi -->
            <StackPanel Grid.Row="4" VerticalAlignment="Center" Margin="0,15,0,0">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" FontWeight="Bold" FontSize="14" 
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}" TextAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="6" Margin="0,8,0,0" Foreground="#393E46" 
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
